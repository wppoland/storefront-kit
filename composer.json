{
    "name": "wppoland/storefront-kit",
    "description": "Shared storefront engines for WPPoland WooCommerce plugins",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "autoload": {
        "psr-4": {
            "WPPoland\\StorefrontKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WPPoland\\StorefrontKit\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6",
        "php-stubs/woocommerce-stubs": "^9.0",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10",
        "szepeviktor/phpstan-wordpress": "^1.3"
    },
    "scripts": {
        "analyse": "phpstan analyse -c phpstan.neon.dist --memory-limit=2G",
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
